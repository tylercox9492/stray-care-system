### Register a new user
POST http://localhost:8080/api/auth/register
Content-Type: application/json

{
  "name": "Nessa Savard",
  "email": "nessa@straycare.com",
  "passwordHash": "password123",
  "role": "ADMIN"
}

###  Login
POST http://localhost:8080/api/auth/login
Content-Type: application/json

{
  "email": "nessa@straycare.com",
  "password": "password123"
}

### Create a dog
POST http://localhost:8080/api/dogs
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJuZXNzYUBzdHJheWNhcmUuY29tIiwicm9sZSI6IkFETUlOIiwiaWF0IjoxNzc0NjMxOTE0LCJleHAiOjE3NzQ3MTgzMTR9.xJs6S-5RNDXIcCk3NfOz0__dCKTNffZuL_5mHU4zZfw

{
  "name": "Buddy",
  "breed": "Labrador",
  "status": "active"
}

### Get all dogs
GET http://localhost:8080/api/dogs

### Create a dog with QR code
POST http://localhost:8080/api/dogs
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJuZXNzYUBzdHJheWNhcmUuY29tIiwicm9sZSI6IkFETUlOIiwiaWF0IjoxNzc0OTA2MDM3LCJleHAiOjE3NzQ5OTI0Mzd9.LTbrrpo4u3IGZ7fC-qLKSOI8nAeHO5ss0mHt3LqQrtM

{
  "name": "Max",
  "breed": "Golden Retriever",
  "status": "active"
}
### Get all sightings (for heatmap)
GET http://localhost:8080/api/sightings

### Submit a sighting with verified field
POST http://localhost:8080/api/sightings
Content-Type: application/json

{
  "dog": { "id": 1 },
  "latitude": 45.3456,
  "longitude": -75.6789,
  "notes": "Spotted near the park",
  "verified": false
}
### Verify a sighting
PUT http://localhost:8080/api/sightings/1/verify
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJuZXNzYUBzdHJheWNhcmUuY29tIiwicm9sZSI6IlZPTFVOVEVFUiIsImlhdCI6MTc3NDkxOTgzNywiZXhwIjoxNzc1MDA2MjM3fQ.Ofe66loPdDLpArsDXZFV8-h09r4zj9FP9RZ6uG2vQ8M
### Get all health records
GET http://localhost:8080/api/health-records
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJuZXNzYUBzdHJheWNhcmUuY29tIiwicm9sZSI6IlZPTFVOVEVFUiIsImlhdCI6MTc3NDkxOTgzNywiZXhwIjoxNzc1MDA2MjM3fQ.Ofe66loPdDLpArsDXZFV8-h09r4zj9FP9RZ6uG2vQ8M
### Search dogs by name
GET http://localhost:8080/api/dogs/search?name=Buddy

### Search dogs by status
GET http://localhost:8080/api/dogs/search?status=active

